{
  "name": "my-pi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix . || true",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "0.67.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "simple-git-hooks": "^2.11.0",
    "typescript": "^5.4.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:fix && pnpm format:fix && git add -u"
  }
}
